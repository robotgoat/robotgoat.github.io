---
import { Image } from "astro:assets";
import ThemeSwitcher from "./ThemeSwitcher.astro";
const { sideBarActiveItemID } = Astro.props;
---

<div class="drawer-side z-40">
  <label for="my-drawer" class="drawer-overlay"></label>
  <aside
    class="px-2 pt-2 h-auto min-h-full w-[19rem] bg-base-200 text-base-content flex flex-col"
  >
    <div class="w-fit mx-auto mt-4 mb-6">
      <a href="/">
        <div
          class="avatar transition ease-linear hover:scale-[104%] block m-auto"
        >
          <div class="w-auto">
            <Image
              class="mask mask-circle"
              format="png"
              width="400"
              height="400"
              src="/trailerparkpilot_logo.png"
              alt="Profile image"
            />
          </div>
        </div>
      </a>
    </div>
    <!-- Sidebar menu start -->
    <div class="text-center">
      <p class="text-3xl">Welcome</p>
      <p class="text-sm">I am currently lost in the desert.</p>
    </div>

    <ThemeSwitcher />

    <ul
      class="menu menu-lg bg-base-200 rounded-box w-56 grow shrink overflow-y-auto"
    >
      <li><a id="home" href="/">Home</a></li>
      <li><a id="blog" href="/blog">Blog</a></li>
    </ul>
    <div
      class="block sticky pointer-events-none bottom-10 bg-base-200 justify-center h-12 [mask-image:linear-gradient(transparent,#000000)]"
    >
    </div>
    <div
      class="footer footer-center px-4 pb-8 pt-1 self-center justify-center bottom-0 bg-base-200 sticky text-base-content rounded overflow-x-auto"
    >
      <a
        href="https://www.youtube.com/@TrailerParkPilot"
        target="_blank"
        class="mx-3"
        aria-label="Youtube"
        title="Youtube"
      >
        <svg
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
          width="40"
          class="fill-current"
          ><title>YouTube</title><path
            d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
          ></path></svg
        >
      </a>
      <a
        href="https://www.printables.com/@GooseDuck_2024920"
        target="_blank"
        class="mx-3"
        aria-label="Printables"
        title="Printables"
      >
        <svg
          role="img"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
          width="40"
          class="fill-current"
          ><title>Printables</title><path
            d="M3.678 4.8 12 9.6v9.6l8.322-4.8V4.8L12 0ZM12 19.2l-8.322-4.8V24Z"
          ></path></svg
        >
      </a>
      <a
        href="https://github.com/robotgoat"
        target="_blank"
        class="mx-3"
        aria-label="Github"
        title="Github"
      >
        <svg
          role="img"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
          width="40"
          class="fill-current"
          ><title>GitHub</title><path
            d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
          ></path></svg
        >
      </a>
    </div>
  </aside>
</div>
