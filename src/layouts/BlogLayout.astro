---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  pubDate: string;
  heroImage?: string;
  activeId?: string;
  tags?: string[];
  badge?: string;
}

const { title, description, pubDate, heroImage, activeId, tags, badge } = Astro.props;
---

<BaseLayout title={title} description={description} activeId={activeId}>
  <article class="prose prose-lg prose-img:mx-auto max-w-none">
    <header class="mb-8 not-prose flex items-start gap-8">
      {
        heroImage && (
          <div class="flex-shrink-0 overflow-hidden rounded-lg">
            <img
              src={heroImage}
              alt={title}
              class="h-32 w-32 object-contain hover:scale-105 transition-transform duration-300"
            />
          </div>
        )
      }
      <div class="flex-1">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">{title}</h1>
        <div class="flex flex-wrap items-center gap-4 text-base-content/70">
        {
          pubDate && (
            <time datetime={pubDate} class="text-sm">
              {new Date(pubDate).toLocaleDateString("en-UK", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </time>
          )
        }
        {description && <p class="text-sm md:text-base">{description}</p>}
        </div>
        {badge && <div class="badge badge-accent my-1">{badge}</div>}
        {
          tags &&
            tags.map((tag) => (
              <a
                href={`/blog/tag/${tag}`}
                class="badge badge-outline ml-2 no-underline"
              >
                {tag}
              </a>
            ))
        }
        <div
          class="h-1 bg-gradient-to-r from-primary to-secondary rounded-full mt-4"
        >
        </div>
      </div>
    </header>

    <div class="my-8">
      <slot />
    </div>
  </article>

  <!-- Navigation -->
  <div class="mt-16 pt-8 border-t border-base-300">
    <a href="/blog" class="btn btn-outline">← Back to Blog</a>
  </div>
</BaseLayout>
